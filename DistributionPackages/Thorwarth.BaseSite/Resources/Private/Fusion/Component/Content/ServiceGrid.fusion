prototype(Thorwarth.BaseSite:Component.Content.ServiceGrid) < prototype(Neos.Fusion:Component) {
    headline = ${q(node).property('headline')}
    subheadline = ${q(node).property('subheadline')}
    backgroundColor = ${q(node).property('backgroundColor') || 'gray'}
    
    services = Neos.Neos:ContentCollection {
        nodePath = 'services'
    }

    renderer = afx`
        <section class={'py-16 ' + (props.backgroundColor == 'gray' ? 'bg-caspary-gray-light' : 'bg-white')}>
            <div class="container mx-auto px-4">
                <div class="text-center mb-12" @if.hasHeader={props.headline || props.subheadline}>
                    <h2 class="text-3xl md:text-4xl font-bold text-primary-800 mb-4" @if.hasHeadline={props.headline}>
                        {props.headline}
                    </h2>
                    <p class="text-lg text-secondary-500 font-medium max-w-2xl mx-auto" @if.hasSubheadline={props.subheadline}>
                        {props.subheadline}
                    </p>
                </div>

                {/* Service Cards Grid */}
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {props.services}
                </div>
            </div>
        </section>
    `
}

prototype(Thorwarth.BaseSite:Content.ServiceGrid) < prototype(Thorwarth.BaseSite:Component.Content.ServiceGrid)
