prototype(Thorwarth.BaseSite:Content.DownloadSection) < prototype(Neos.Neos:ContentCollection) {
    renderer = afx`
        <section class="download-section py-12">
            <div class="container mx-auto px-4">
                <Neos.Neos:ContentCollection nodePath="." @context.node={node}>
                    <div class="space-y-6">
                        {props.content}
                    </div>
                </Neos.Neos:ContentCollection>
            </div>
        </section>
    `
}
